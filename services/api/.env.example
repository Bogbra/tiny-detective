# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Shared-secret header for /admin/cases/* routes. Unset (or empty) disables
# admin routes entirely (every request gets 401). See app/api/dependencies.py.
ADMIN_API_TOKEN=

# Used by the AI Hint Assistant (app/infrastructure/ai/ai_hint_assistant.py).
# Unset is safe: the hint endpoint falls back to a deterministic hint instead
# of erroring. Never logged.
OPENAI_API_KEY=

# Point at a local Firestore emulator, e.g.:
#   docker run -d -p 8080:8080 gcr.io/google.com/cloudsdktool/cloud-sdk:emulators \
#     gcloud emulators firestore start --host-port=0.0.0.0:8080
# then FIRESTORE_EMULATOR_HOST=localhost:8080
# Unset is safe: repositories fall back to in-memory (Phase 3 behavior) —
# see app/infrastructure/firestore/firestore_client.py.
FIRESTORE_EMULATOR_HOST=
GOOGLE_CLOUD_PROJECT=
